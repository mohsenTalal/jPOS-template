#!/bin/sh

export JAVA_HOME=$(/usr/libexec/java_home -v 25)
export PATH="$JAVA_HOME/bin:$PATH"

cd `dirname $0`/.. || exit 1
rm -f deploy/shutdown.xml

if [ -f jpos.pid ] && ps -p $(cat jpos.pid) > /dev/null 2>&1
then
   echo "Process $(cat jpos.pid) is running"
else
  rm -f jpos.pid
  exec "$JAVA_HOME/bin/java" -server \
    -XX:+IgnoreUnrecognizedVMOptions \
    -Xmx1G \
    -Djava.net.preferIPv4Stack=true \
    -cp "jPOS-template-3.0.1-SNAPSHOT-plain.jar:lib/*" \
    org.jpos.q2.Q2 --pid="jpos.pid" "$@"
fi