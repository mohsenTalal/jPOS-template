<txnmgr name='txnmgr'
        class='org.jpos.transaction.TransactionManager'
        logger='Q2'
        realm='txnmgr'>

    <property name='queue' value='echo-request'/>
    <property name='sessions' value='2'/>

    <!-- 1. Authorize via CyberSource or set response code -->
    <participant class='com.example.api.CyberSourceAuthParticipant' logger='Q2'/>

    <!-- 2. Build and send ISO-8583 response back to client -->
    <participant class='com.example.api.ResponseBuilderParticipant' logger='Q2'/>

</txnmgr>

